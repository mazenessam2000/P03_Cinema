<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CinemaVerse — @ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/customer/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer/profilepage.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer/verifypage.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer/editprofile.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- ══════════════════════════════════════════════════════════ NAVBAR -->
    <nav class="cv-navbar navbar navbar-expand-lg">

        <!-- Brand -->
        <a class="cv-brand" asp-controller="Home" asp-action="Index">
            CINEMA<span style="color:#fff;opacity:.25">VERSE</span>
        </a>

        <!-- Mobile toggler -->
        <button class="navbar-toggler ms-auto me-2" type="button"
                data-bs-toggle="collapse" data-bs-target="#cvNav"
                aria-controls="cvNav" aria-expanded="false">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="cvNav">

            <!-- LEFT NAV -->
            <ul class="cv-nav-links navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Movies" asp-action="Index">
                        <i class="fa fa-film me-1 opacity-50"></i> Movies
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Series" asp-action="Index">
                        <i class="fa fa-tv me-1 opacity-50"></i> Series
                    </a>
                </li>

                <!-- Categories dropdown -->
                <li class="nav-item dropdown cv-dropdown">
                    <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown">
                        <i class="fa fa-layer-group me-1 opacity-50"></i> Categories
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item"><i class="fa fa-bolt"></i> Action</a></li>
                        <li><a class="dropdown-item"><i class="fa fa-face-laugh"></i> Comedy</a></li>
                        <li><a class="dropdown-item"><i class="fa fa-ghost"></i> Horror</a></li>
                        <li><a class="dropdown-item"><i class="fa fa-rocket"></i> Sci-Fi</a></li>
                        <li><a class="dropdown-item"><i class="fa fa-masks-theater"></i> Drama</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item"><i class="fa fa-grid-2"></i> All Genres <span class="item-badge">18</span></a></li>
                    </ul>
                </li>
            </ul>

            <!-- RIGHT: search + user -->
            <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">

                <!-- Search -->
                <div class="cv-search d-none d-lg-block">
                    <i class="fa fa-magnifying-glass search-icon"></i>
                    <input type="text" placeholder="Search titles..." />
                </div>

                @if (User is not null && User.Identity.IsAuthenticated)
                {
                    <!-- User pill dropdown -->
                    <div class="dropdown cv-dropdown">
                        <div class="cv-user-pill dropdown-toggle" data-bs-toggle="dropdown" role="button">
                            <img src="https://i.pravatar.cc/150?u=@User.Identity.Name"
                                 class="avatar-mini" alt="Avatar" />
                            @User.Identity.Name
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                    <i class="fa fa-id-card"></i> My Profile
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post">
                                    <button class="dropdown-item" style="color:#e57070">
                                        <i class="fa fa-right-from-bracket"></i> Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="cv-btn-login" asp-area="Identity" asp-controller="Account" asp-action="Login">
                        Login
                    </a>
                    <a class="cv-btn-register" asp-area="Identity" asp-controller="Account" asp-action="Register">
                        Register
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- ══════════════════════════════════════════════════════════ CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- ══════════════════════════════════════════════════════════ FOOTER -->
    <footer class="cv-footer">
        <div class="footer-brand">CINEMAVERSE</div>
        <p>© 2026 CinemaVerse. All rights reserved. &nbsp;·&nbsp; Made with 🎬</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- ★ CinemaVerse shared scripts -->
    <script src="~/js/Customer/cinemaverse.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
