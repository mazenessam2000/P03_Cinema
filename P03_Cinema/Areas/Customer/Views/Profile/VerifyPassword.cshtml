@model VerifyPasswordVM

@{
    ViewData["Title"] = "Confirm Identity";
}

<div class="cv-page-wrap cv-animate">
    <div class="cv-surface">

        <div class="cv-page-header">
            <div class="page-icon">🔒</div>
            <h4>Confirm Your Identity</h4>
            <p>Enter your current password to access profile settings</p>
        </div>

        <div class="cv-page-body">

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="cv-alert cv-alert-error">
                    <i class="fa fa-triangle-exclamation"></i>
                    @ViewData.ModelState[""].Errors[0].ErrorMessage
                </div>
            }

            <form asp-action="VerifyPassword" method="post">
                @Html.AntiForgeryToken()

                <div class="cv-field-group">
                    <label class="cv-label">Current Password</label>
                    <div class="cv-input-wrap">
                        <i class="fa fa-lock cv-input-icon"></i>
                        <input asp-for="Password"
                               type="password"
                               class="cv-input has-icon has-eye"
                               placeholder="••••••••"
                               id="verifyPwd" />
                        <button type="button" class="cv-eye" data-eye="verifyPwd">👁</button>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <button type="submit" class="cv-btn cv-btn-primary cv-btn-full mt-2">
                    Confirm &amp; Continue <i class="fa fa-arrow-right ms-1"></i>
                </button>
            </form>

            <a asp-action="Index" class="d-block text-center mt-3"
                   style="font-size:13px;color:var(--text-muted)">
                ← Back to Profile
            </a>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
