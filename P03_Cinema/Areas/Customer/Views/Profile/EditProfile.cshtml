@model EditProfileVM

@{
    ViewData["Title"] = "Edit Profile";

    // ✅ Detect password-related validation errors
    var hasPasswordErrors =
        ViewData.ModelState["NewPassword"]?.Errors.Count > 0 ||
        ViewData.ModelState["ConfirmNewPassword"]?.Errors.Count > 0 ||
        ViewData.ModelState["CurrentPassword"]?.Errors.Count > 0;
}

<div class="cv-page-wrap-md cv-animate">
    <div class="cv-surface">

        <!-- Header -->
        <div class="cv-page-header-inline">
            <div style="font-size:26px">✏️</div>
            <div>
                <h4>Edit Profile</h4>
                <p>Update your account details below</p>
            </div>
        </div>

        <div class="cv-page-body">

            @if (TempData["Success"] != null)
            {
                <div class="cv-alert cv-alert-success">
                    <i class="fa fa-circle-check"></i> @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="cv-alert cv-alert-error">
                    <i class="fa fa-triangle-exclamation"></i> @TempData["Error"]
                </div>
            }

            <form asp-action="EditProfile" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="cv-alert cv-alert-error">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <!-- PERSONAL INFO -->
                <div class="cv-section-divider">Personal Info</div>

                <div class="row g-3 mb-1">
                    <div class="col-6">
                        <div class="cv-field-group">
                            <label class="cv-label">First Name</label>
                            <input asp-for="FirstName" class="cv-input" placeholder="John" />
                            <span asp-validation-for="FirstName" class="field-validation-error"></span>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="cv-field-group">
                            <label class="cv-label">Last Name</label>
                            <input asp-for="LastName" class="cv-input" placeholder="Doe" />
                            <span asp-validation-for="LastName" class="field-validation-error"></span>
                        </div>
                    </div>
                </div>

                <div class="cv-field-group">
                    <label class="cv-label">Username</label>
                    <div class="cv-input-wrap">
                        <i class="fa fa-at cv-input-icon"></i>
                        <input asp-for="Username" class="cv-input has-icon" placeholder="johndoe" />
                    </div>
                    <span asp-validation-for="Username" class="field-validation-error"></span>
                </div>

                <div class="cv-field-group">
                    <label class="cv-label">Email</label>
                    <div class="cv-input-wrap">
                        <i class="fa fa-envelope cv-input-icon"></i>
                        <input asp-for="Email" class="cv-input has-icon" type="email" placeholder="john@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <!-- SECURITY -->
                <div class="cv-section-divider mt-3">Security</div>

                <button type="button"
                        class="cv-collapse-toggle"
                        data-toggle="pwdSection"
                        data-toggle-open-text="🔑 Change Password (optional)"
                        data-toggle-close-text="🔑 Cancel Password Change">
                    🔑 Change Password <span style="opacity:.45;font-size:11px;font-weight:400">(optional)</span>
                </button>

                <div class="cv-collapsible @(hasPasswordErrors ? "open" : "")" id="pwdSection">

                    <div class="cv-field-group">
                        <label class="cv-label">Current Password</label>

                        <div class="cv-input-wrap">
                            <i class="fa fa-lock cv-input-icon"></i>

                            <input asp-for="CurrentPassword"
                                   type="password"
                                   class="cv-input has-icon has-eye"
                                   placeholder="Enter current password"
                                   id="currentPwd" />

                            <button type="button" class="cv-eye" data-eye="currentPwd">👁</button>
                        </div>

                        <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
                    </div>

                    <!-- New Password -->
                    <div class="cv-field-group">
                        <label class="cv-label">New Password</label>
                        <div class="cv-input-wrap">
                            <i class="fa fa-lock cv-input-icon"></i>
                            <input asp-for="NewPassword"
                                   type="password"
                                   class="cv-input has-icon has-eye"
                                   placeholder="••••••••"
                                   id="newPwd"
                                   data-clear-on-close
                                   data-strength-fill="strengthFill"
                                   data-strength-hint="strengthHint" />
                            <button type="button" class="cv-eye" data-eye="newPwd">👁</button>
                        </div>

                        <div class="cv-strength-bar">
                            <div class="cv-strength-fill" id="strengthFill"></div>
                        </div>

                        <span class="cv-strength-hint" id="strengthHint"></span>
                        <span asp-validation-for="NewPassword" class="field-validation-error"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="cv-field-group">
                        <label class="cv-label">Confirm New Password</label>
                        <div class="cv-input-wrap">
                            <i class="fa fa-lock cv-input-icon"></i>
                            <input asp-for="ConfirmNewPassword"
                                   type="password"
                                   class="cv-input has-icon has-eye"
                                   placeholder="••••••••"
                                   id="confirmPwd"
                                   data-clear-on-close />
                            <button type="button" class="cv-eye" data-eye="confirmPwd">👁</button>
                        </div>

                        <span asp-validation-for="ConfirmNewPassword" class="field-validation-error"></span>
                    </div>

                </div>

                <!-- ACTIONS -->
                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Index" class="cv-btn cv-btn-ghost">
                        <i class="fa fa-arrow-left"></i> Cancel
                    </a>

                    <button type="submit" class="cv-btn cv-btn-primary flex-grow-1">
                        <i class="fa fa-floppy-disk"></i> Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}