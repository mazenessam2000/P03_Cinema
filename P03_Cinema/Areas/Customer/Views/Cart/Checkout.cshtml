@model CheckoutVM

<div class="container py-4" style="max-width:700px;">

    <h4 class="mb-4">✅ Confirm Booking</h4>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <table class="table align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Movie</th>
                        <th>Seat</th>
                        <th>Showtime</th>
                        <th class="text-end">Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Cart.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.MovieName</td>
                            <td>
                                <span class="badge bg-primary">@item.SeatLabel</span>
                                <small class="text-muted d-block">@item.HallName</small>
                            </td>
                            <td>@item.ShowTime.ToString("ddd dd MMM, h:mm tt")</td>
                            <td class="text-end">$@item.Price</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-light fw-bold">
                        <td colspan="3" class="text-end">Total</td>
                        <td class="text-end text-primary fs-5">$@Model.Cart.Total</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="alert alert-info">
        By confirming, You will be redirected to a secure payment page to complete your booking.
    </div>

    <div class="d-flex gap-2">
        <form asp-action="ConfirmCheckout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success fw-semibold px-4"
                    onclick="this.disabled=true; this.innerText='Redirecting...'; this.form.submit();">
                🎟 Confirm & Pay
            </button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">← Back to Cart</a>
    </div>

</div>
