@model SeatMapVM

<div class="container py-4 seatmap-container">

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4>🎬 @Model.MovieName</h4>
                <div class="text-muted small">
                    🏛 @Model.CinemaName · 🎭 @Model.HallName ·
                    🕐 @Model.StartTime.ToString("ddd dd MMM yyyy, hh:mm tt")
                </div>
            </div>

            <div class="text-end">
                <div class="fw-bold text-primary">
                    $@Model.PricePerSeat / seat
                </div>
                <a asp-controller="Cart" asp-action="Index"
                   class="btn btn-success btn-sm">
                    🛒 View Cart
                </a>
            </div>
        </div>
    </div>

    <div class="legend text-center mb-3">
        <span class="seat-dot available"></span> Available
        <span class="seat-dot selected"></span> In Cart
        <span class="seat-dot reserved"></span> Reserved
        <span class="seat-dot booked"></span> Booked
        <span class="seat-dot vip"></span> VIP
    </div>

    <div class="screen-wrapper">
        <div class="screen-text">SCREEN THIS WAY</div>
        <div class="screen"></div>
    </div>

    <div class="text-center text-muted small mb-3">
        Click seats to add/remove them
    </div>

    <div class="seat-map">

        @foreach (var row in Model.Rows)
        {
            <div class="seat-row">

                <div class="row-label">@row.RowLabel</div>

                <div class="row-seats">
                    @for (int i = 0; i < row.Seats.Count; i++)
                    {
                        var seat = row.Seats[i];

                        if (i == row.Seats.Count / 2)
                        {
                            <div class="aisle-gap"></div>
                        }

                        var css = "seat";

                        css += seat.Status switch
                        {
                            SeatStatus.Booked => " booked",
                            SeatStatus.Reserved => seat.IsReservedByMe ? " in-cart" : " reserved",
                            _ => seat.Type == SeatType.VIP ? " vip" : " available"
                        };

                        var disabled = seat.Status == SeatStatus.Booked ||
                                       (seat.Status == SeatStatus.Reserved && !seat.IsReservedByMe);

                        if (seat.IsInMyCart && seat.CartItemId != null)
                        {
                            <form asp-controller="Cart" asp-action="RemoveSeat" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@seat.CartItemId" />
                                <button class="@css">@seat.Label</button>
                            </form>
                        }
                        else if (!disabled)
                        {
                            <form asp-controller="Cart" asp-action="AddSeat" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="showTimeSeatId" value="@seat.ShowTimeSeatId" />
                                <input type="hidden" name="showTimeId" value="@Model.ShowTimeId" />
                                <button class="@css">@seat.Label</button>
                            </form>
                        }
                        else
                        {
                            <button class="@css" disabled>@seat.Label</button>
                        }
                    }
                </div>

                <div class="row-label">@row.RowLabel</div>
            </div>
        }

    </div>
</div>

@section Styles {
<style>

body { background:#0b0f17; }

.seat-map { display:flex; flex-direction:column; gap:12px; }

.seat-row {
    display:flex;
    justify-content:center;
    align-items:center;
    gap:12px;
}

.row-label {
    width:30px;
    text-align:center;
    color:#aaa;
}

.row-seats {
    display:flex;
    gap:8px;
}

.aisle-gap { width:30px; }

.seat {
    width:42px;
    height:38px;
    border:none;
    border-radius:8px;
    font-size:11px;
    cursor:pointer;
}

.seat.available { background:#198754; color:white; }
.seat.vip { background:#ffc107; color:black; }
.seat.in-cart { background:#0d6efd; color:white; }
.seat.reserved { background:#6c757d; color:white; }
.seat.booked { background:#dc3545; color:white; opacity:0.5; }

.screen {
    height:12px;
    width:70%;
    margin:10px auto;
    background:linear-gradient(90deg, transparent, #0d6efd, transparent);
    border-radius:50%;
}

.screen-text {
    text-align:center;
    font-size:10px;
    color:#888;
    letter-spacing:4px;
}

.legend { color:#ccc; }

.seat-dot {
    display:inline-block;
    width:12px;
    height:12px;
    margin:0 5px;
    border-radius:3px;
}

.available { background:#198754; }
.selected { background:#0d6efd; }
.reserved { background:#6c757d; }
.booked { background:#dc3545; }
.vip { background:#ffc107; }

</style>
}