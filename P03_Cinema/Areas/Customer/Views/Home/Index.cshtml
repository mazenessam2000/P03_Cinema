@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<div class="hero text-white rounded mb-5">
    <div>
        <h1 class="display-4 fw-bold">Welcome to CinemaVerse</h1>
        <p class="lead">Unlimited Movies, Series & Entertainment in one place</p>
        <a class="btn btn-danger btn-lg mt-3">Watch Now</a>
    </div>
</div>

<!-- CATEGORIES -->
<div class="mb-4">
    <h4 class="mb-3">🎭 Categories</h4>

    <div class="d-flex flex-wrap gap-2">
        <span class="badge bg-secondary p-2">Action</span>
        <span class="badge bg-secondary p-2">Comedy</span>
        <span class="badge bg-secondary p-2">Horror</span>
        <span class="badge bg-secondary p-2">Sci-Fi</span>
        <span class="badge bg-secondary p-2">Drama</span>
        <span class="badge bg-secondary p-2">Romance</span>
        <span class="badge bg-secondary p-2">Thriller</span>
    </div>
</div>

<!-- POPULAR MOVIES -->
<div class="mb-5">
    <h4 class="mb-3">🔥 Popular Movies</h4>

    <div class="row g-4">

        <!-- Movie 1 -->
        <div class="col-md-3">
            <div class="card card-dark">
                <img src="https://image.tmdb.org/t/p/w500/8UlWHLMpgZm9bx6QYh0NFoq67TZ.jpg" class="card-img-top">
                <div class="card-body">
                    <h6>Wonder Woman</h6>
                    <small>Action • ⭐ 7.4</small>
                </div>
            </div>
        </div>

        <!-- Movie 2 -->
        <div class="col-md-3">
            <div class="card card-dark">
                <img src="https://image.tmdb.org/t/p/w500/qJ2tW6WMUDux911r6m7haRef0WH.jpg" class="card-img-top">
                <div class="card-body">
                    <h6>The Dark Knight</h6>
                    <small>Action • ⭐ 9.0</small>
                </div>
            </div>
        </div>

        <!-- Movie 3 -->
        <div class="col-md-3">
            <div class="card card-dark">
                <img src="https://image.tmdb.org/t/p/w500/6DrHO1jr3qVrViUO6s6kFiAGM7.jpg" class="card-img-top">
                <div class="card-body">
                    <h6>Interstellar</h6>
                    <small>Sci-Fi • ⭐ 8.6</small>
                </div>
            </div>
        </div>

        <!-- Movie 4 -->
        <div class="col-md-3">
            <div class="card card-dark">
                <img src="https://image.tmdb.org/t/p/w500/udDclJoHjfjb8Ekgsd4FDteOkCU.jpg" class="card-img-top">
                <div class="card-body">
                    <h6>Joker</h6>
                    <small>Drama • ⭐ 8.4</small>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- TRENDING -->
<div class="mb-5">
    <h4 class="mb-3">📈 Trending Now</h4>

    <div class="row g-3">

        <div class="col-md-6">
            <div class="card card-dark p-3">
                <h5>Fast X</h5>
                <p class="mb-0">High-speed action continues with explosive racing scenes.</p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card card-dark p-3">
                <h5>Conjuring Universe</h5>
                <p class="mb-0">Top horror franchise full of supernatural cases.</p>
            </div>
        </div>

    </div>
</div>