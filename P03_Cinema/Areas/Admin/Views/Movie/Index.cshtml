@model MovieIndexVM

<div class="container-fluid">
    <div class="d-flex justify-content-between mb-4">
        <h4>Movies</h4>
        <a asp-action="Create" class="btn btn-primary">+ Add Movie</a>
    </div>

    <div class="row g-4">

        @foreach (var movie in Model.Movies)
        {
            <div class="col-md-3 mb-4">
                <div class="card border-0 shadow-sm text-white">

                    <img src="~/Assets/Admin/img/movie/@movie.MainImage"
                         class="card-img"
                         style="height:360px; object-fit:cover;">

                    <div class="card-img-overlay d-flex flex-column justify-content-end"
                         style="background: linear-gradient(to top, rgba(0,0,0,0.6), rgba(0,0,0,0.1)); padding:1rem;">

                        <h5 class="movie-name-glow">@movie.Name</h5>

                        <p class="small text-white-50">
                            @movie.ReleaseDate.Year • @movie.Status
                        </p>

                        <!-- Actors -->
                        <div class="mb-2">
                            @if (Model.MovieActors.ContainsKey(movie.Id))
                            {
                                foreach (var actor in Model.MovieActors[movie.Id])
                                {
                                    <span class="badge bg-light text-dark">@actor</span>
                                }
                            }
                        </div>

                        <!-- Categories -->
                        <div class="mb-2">
                            @if (Model.MovieCategories.ContainsKey(movie.Id))
                            {
                                foreach (var cat in Model.MovieCategories[movie.Id])
                                {
                                    <span class="badge bg-dark">@cat</span>
                                }
                            }
                        </div>

                        <div class="d-flex gap-2">
                            <a asp-action="Update" asp-route-id="@movie.Id"
                               class="btn btn-sm btn-light">Edit</a>

                            <a href="#"
                               onclick="deleteMovie(event,@movie.Id)"
                               class="btn btn-sm btn-danger">Delete</a>
                        </div>

                    </div>
                </div>
            </div>
        }

    </div>

    <!-- ✅ PAGINATION -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            <!-- Previous -->
            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)">
                    Previous
                </a>
            </li>

            <!-- Numbers -->
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <!-- Next -->
            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)">
                    Next
                </a>
            </li>

        </ul>

        <div class="text-center text-muted mt-2">
            Page @Model.CurrentPage of @Model.TotalPages
        </div>
    </nav>
</div>

@section Styles {
    <style>
        .movie-name-glow {
            color: White;
            text-shadow: 0 0 5px Blue;
        }
    </style>
}

@section Scripts {
    <script>
        function deleteMovie(e,id){
            e.preventDefault();

            if(!confirm("Delete this movie?")) return;

            fetch(`/Admin/Movie/Delete/${id}`,{
                method:"POST"
            })
            .then(r=>{
                if(r.ok) location.reload();
            });
        }
    </script>
}