@model ActorWithMoviesCountVM

<div class="container-fluid">
    <div class="d-flex justify-content-between mb-4">
        <h4>Actors</h4>
        <a asp-action="Create" class="btn btn-primary">+ Add Actor</a>
    </div>

    <div class="row g-4">
        @foreach (var actor in Model.Actors)
        {
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-white">
                    <img src="~/Assets/Admin/img/actor/@actor.ImageUrl"
                         class="card-img"
                         style="height:320px; object-fit:cover;">

                    <div class="card-img-overlay d-flex flex-column justify-content-end"
                         style="background: linear-gradient(to top, rgba(0,0,0,0.6), rgba(0,0,0,0.1));">

                        <h5 class="actor-name-glow">@actor.FullName</h5>

                        <p class="small text-white-50">
                            Age: @(actor.BirthDate.HasValue ? DateTime.Now.Year - actor.BirthDate.Value.Year : 0)
                            • 🎬 @(Model.ActorMovieCounts.ContainsKey(actor.Id) ? Model.ActorMovieCounts[actor.Id] : 0)
                        </p>

                        <div class="d-flex gap-2">
                            <a asp-action="Update" asp-route-id="@actor.Id" class="btn btn-sm btn-light">Edit</a>
                            <a href="#" onclick="deleteActor(event,@actor.Id)" class="btn btn-sm btn-danger">Delete</a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ✅ PAGINATION -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            <!-- Previous -->
            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)">
                    Previous
                </a>
            </li>

            <!-- Numbers -->
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <!-- Next -->
            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)">
                    Next
                </a>
            </li>

        </ul>

        <div class="text-center text-muted mt-2">
            Page @Model.CurrentPage of @Model.TotalPages
        </div>
    </nav>
</div>

@section Styles {
    <style>
        .actor-name-glow {
            color: white;
            text-shadow: 0 0 5px black;
        }
    </style>
}

@section Scripts {
    <script>
        function deleteActor(e,id){
            e.preventDefault();
            if(!confirm("Delete this actor?")) return;

            fetch(`/Admin/Actor/Delete/${id}`,{method:"POST"})
                .then(r => { if(r.ok) location.reload(); });
        }
    </script>
}