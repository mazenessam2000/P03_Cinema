@model ActorCreateVM

<div class="container-fluid py-4">

    <h2 class="mb-4">Create Actor</h2>

    <div class="card shadow-sm">
        <div class="card-body">

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Actor.FullName" class="form-label"></label>
                    <input asp-for="Actor.FullName" class="form-control" />
                    <span asp-validation-for="Actor.FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Actor.BirthDate" class="form-label"></label>
                    <input asp-for="Actor.BirthDate" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Actor.Bio" class="form-label"></label>
                    <textarea asp-for="Actor.Bio" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Actor Image</label>
                    <input asp-for="Img" type="file" class="form-control" />
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-dark">← Back</a>
                    <button type="submit" class="btn btn-primary">Create Actor</button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(event) {
            const preview = document.getElementById('preview');
            const file = event.target.files[0];
            if (!file) return;

            preview.src = URL.createObjectURL(file);
            preview.style.display = 'block';
        }
    </script>
}