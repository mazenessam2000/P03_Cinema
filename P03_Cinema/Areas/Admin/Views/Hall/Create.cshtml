@model HallCreateVM

@{
    var cinemas = Model?.Cinemas ?? new List<Cinema>();
}

<div class="container py-4" style="max-width:600px;">

    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back</a>
        <h4 class="mb-0">Create Hall</h4>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">

            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="alert alert-danger mb-3" style="display:none"></div>

                <!-- Cinema -->
                <div class="mb-3">
                    <label asp-for="CinemaId" class="form-label fw-semibold">Cinema</label>
                    <select asp-for="CinemaId"
                            asp-items="@(new SelectList(cinemas, "Id", "Name"))"
                            class="form-select">
                        <option value="">— Select Cinema —</option>
                    </select>
                    <span asp-validation-for="CinemaId" class="text-danger small"></span>
                </div>

                <!-- Name -->
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Hall Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Hall A, IMAX 1" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <!-- Rows -->
                    <div class="col-6">
                        <label asp-for="TotalRows" class="form-label fw-semibold">Total Rows</label>
                        <input asp-for="TotalRows" type="number" min="1" max="100" class="form-control" />
                        <span asp-validation-for="TotalRows" class="text-danger small"></span>
                    </div>

                    <!-- Seats per row -->
                    <div class="col-6">
                        <label asp-for="SeatsPerRow" class="form-label fw-semibold">Seats Per Row</label>
                        <input asp-for="SeatsPerRow" type="number" min="1" max="100" class="form-control" />
                        <span asp-validation-for="SeatsPerRow" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Preview -->
                <div class="alert alert-info small mb-3" id="seatPreview">
                    Total seats: <strong id="previewCount">0</strong>
                    &nbsp;·&nbsp; Seats will be auto-generated (A1, A2 … Z10)
                </div>

                <!-- Active -->
                <div class="form-check mb-4">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create Hall</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const rows = document.getElementById('TotalRows');
        const perRow = document.getElementById('SeatsPerRow');
        const preview = document.getElementById('previewCount');

        function update() {
            const r = parseInt(rows.value) || 0;
            const s = parseInt(perRow.value) || 0;
            preview.textContent = r * s;
        }

        rows.addEventListener('input', update);
        perRow.addEventListener('input', update);
        update();
    </script>
}
