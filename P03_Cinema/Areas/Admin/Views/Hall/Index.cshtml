@model HallIndexVM

@{
    var halls = Model?.Halls ?? new List<HallRowVM>();
    var query = Model?.Query ?? "";
    var currentPage = Model?.CurrentPage ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">🏛 Halls</h4>
        <a asp-action="Create" class="btn btn-primary">+ New Hall</a>
    </div>

    <!-- Search -->
    <form method="get" class="mb-4">
        <div class="input-group" style="max-width:400px;">
            <input type="text" name="q" value="@query"
                   class="form-control" placeholder="Search by hall or cinema..." />
            <button class="btn btn-outline-secondary" type="submit">Search</button>
        </div>
    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Hall Name</th>
                            <th>Cinema</th>
                            <th>Rows</th>
                            <th>Seats/Row</th>
                            <th>Total Seats</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>

                        @if (!halls.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    No halls found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var hall in halls)
                            {
                                <tr>
                                    <td>@hall.Id</td>
                                    <td class="fw-semibold">@hall.Name</td>
                                    <td>@hall.CinemaName</td>
                                    <td>@hall.TotalRows</td>
                                    <td>@hall.SeatsPerRow</td>
                                    <td>
                                        <span class="badge bg-secondary">@hall.TotalSeats seats</span>
                                    </td>
                                    <td>
                                        @if (hall.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Update" asp-route-id="@hall.Id"
                                           class="btn btn-sm btn-outline-primary me-1">Edit</a>

                                        <button class="btn btn-sm btn-outline-danger"
                                                onclick="deleteHall(event, @hall.Id)">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-q="@query">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }

</div>

<!-- Anti-forgery token -->
<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        async function deleteHall(e, id) {
            e.preventDefault();

            if (!confirm('Delete this hall and all its seats?')) return;

            const tokenInput = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            if (!tokenInput) {
                alert("Security token missing.");
                return;
            }

            const token = tokenInput.value;

            try {
                const res = await fetch(`/Admin/Hall/Delete/${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (res.ok) {
                    location.reload();
                } else {
                    alert('Failed to delete hall.');
                }
            } catch {
                alert('Server error.');
            }
        }
    </script>
}