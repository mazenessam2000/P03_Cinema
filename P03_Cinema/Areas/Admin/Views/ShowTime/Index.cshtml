@model ShowTimeIndexVM

<div class="container-fluid">

    <div class="d-flex justify-content-between mb-4">
        <h4>ShowTimes</h4>
        <a asp-action="Create" class="btn btn-primary">+ Add ShowTime</a>
    </div>

    <!-- 🔍 SEARCH -->
    <form method="get" asp-action="Index" class="mb-4">
        <div class="input-group" style="max-width:400px;">
            <input type="text" name="q" value="@Model.SearchQuery"
                   class="form-control" placeholder="Search by movie or cinema..." />

            <button class="btn btn-outline-primary" type="submit">Search</button>

            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @if (!Model.ShowTimes.Any())
    {
        <div class="text-center text-muted py-5">
            No showtimes found.
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var s in Model.ShowTimes ?? Enumerable.Empty<ShowTime>())
            {
                if (s?.Movie == null || s?.Cinema == null || s?.Hall == null)
                {
                    continue;
                }

                var isPast = s.StartTime < DateTime.UtcNow;

                <div class="col-md-4" id="show-@s.Id">
                    <div class="card border-0 shadow-sm text-white">

                        <img src="~/Assets/Admin/img/movie/@(s.Movie?.MainImage ?? "default.jpg")"
                             class="card-img"
                             style="height:220px; object-fit:cover;" />

                        <div class="card-img-overlay d-flex flex-column justify-content-end"
                             style="background: linear-gradient(to top, rgba(0,0,0,.7), transparent);">

                            <h5>@s.Movie.Name</h5>

                            <div class="small text-white-50 mb-2">
                                🏛 @s.Cinema.Name <br />
                                🎭 @s.Hall.Name
                            </div>

                            <div class="d-flex justify-content-between align-items-center">

                                <div>
                                    <div class="fw-semibold">
                                        🕐 @s.StartTime.ToString("ddd dd MMM, h:mm tt")
                                    </div>

                                    @if (isPast)
                                    {
                                        <span class="badge bg-danger mt-1">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success mt-1">Upcoming</span>
                                    }
                                </div>

                                <div class="d-flex gap-2">
                                    <a asp-action="Update"
                                       asp-route-id="@s.Id"
                                       class="btn btn-sm btn-outline-warning">✏️</a>

                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="deleteShowTime(@s.Id)">
                                        🗑
                                    </button>
                                </div>

                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- 🔢 PAGINATION -->
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-q="@Model.SearchQuery">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                               asp-route-page="@i"
                               asp-route-q="@Model.SearchQuery">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-q="@Model.SearchQuery">
                        Next
                    </a>
                </li>

            </ul>

            <div class="text-center text-muted mt-2">
                Page @Model.CurrentPage of @Model.TotalPages
            </div>
        </nav>
    }
</div>

@section Scripts {
    <script>
        function deleteShowTime(id) {
            if (!confirm("Delete this showtime?")) return;

            fetch(`/Admin/ShowTime/Delete/${id}`, {
                method: "POST"
            })
            .then(r => {
                if (r.ok) {
                    document.getElementById(`show-${id}`).remove();
                }
            });
        }
    </script>
}