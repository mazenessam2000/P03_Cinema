@model CinemaCreateVM

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Create Cinema</h2>
    </div>


    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="POST" enctype="multipart/form-data">

                <!-- Cinema Name -->
                <div class="mb-3">
                    <label asp-for="Cinema.Name" class="form-label"></label>
                    <input asp-for="Cinema.Name" class="form-control" placeholder="Enter cinema name" required />
                </div>

                <!-- Location -->
                <div class="mb-3">
                    <label asp-for="Cinema.Location" class="form-label"></label>
                    <input asp-for="Cinema.Location" class="form-control" placeholder="City, Country" required />
                </div>

                <!-- Rating (Read-only) -->
                <div class="mb-3">
                    <label asp-for="Cinema.Rate" class="form-label"></label>
                    <input asp-for="Cinema.Rate" class="form-control text-muted" value="0" readonly />
                    <div class="form-text">Rating is calculated automatically.</div>
                </div>

                <!-- Active toggle -->
                <div class="mb-3 form-check form-switch">
                    <input asp-for="Cinema.IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="Cinema.IsActive" class="form-check-label">Active</label>
                </div>

                <!-- Image Upload -->
                <div class="mb-3">
                    <label class="form-label">Cinema Image</label>
                    <input asp-for="Img" type="file" class="form-control" accept="image/*" />
                </div>

                <!-- Movies Multi-Select -->
                <div class="mb-3">
                    <label class="form-label">Select Movies</label>
                    <select class="form-select select2" name="SelectedMovieIds" multiple="multiple">
                        @foreach (var movie in Model.AllMovies)
                        {
                            <option value="@movie.Id">@movie.Name</option>
                        }
                    </select>
                </div>

                <!-- Submit -->
                <div class="d-flex justify-content-between mt-4">

                    <a asp-area="Admin"
                           asp-controller="Cinema"
                           asp-action="Index"
                           class="btn btn-outline-dark">
                        ← Back to Cinemas
                    </a>

                    <div>
                        <button type="reset" class="btn btn-outline-secondary me-2">Reset</button>
                        <button type="submit" class="btn btn-primary">Add Cinema</button>
                    </div>

                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.select2').select2({
                placeholder: "Search and select movies...",
                allowClear: true,
                width: '100%'
            });
        });
    </script>
}