@model CinemaUpdateVM

<div class="container-fluid py-4">

    <h2 class="mb-4">Update Cinema</h2>

    <div class="card shadow-sm">
        <div class="card-body">

            <form asp-action="Update" method="post" enctype="multipart/form-data">

                <input type="hidden" asp-for="Cinema.Id" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- Name -->
                <div class="mb-3">
                    <label asp-for="Cinema.Name" class="form-label"></label>
                    <input asp-for="Cinema.Name" class="form-control" />
                </div>

                <!-- Location -->
                <div class="mb-3">
                    <label asp-for="Cinema.Location" class="form-label"></label>
                    <input asp-for="Cinema.Location" class="form-control" />
                </div>

                <!-- Total Seats -->
                <div class="mb-3">
                    <label asp-for="Cinema.TotalSeats" class="form-label"></label>
                    <input asp-for="Cinema.TotalSeats" class="form-control" />
                </div>

                <!-- Active -->
                <div class="form-check form-switch mb-3">
                    <input asp-for="Cinema.IsActive" class="form-check-input" />
                </div>

                <!-- Image -->
                <div class="mb-3">
                    <label asp-for="Img" class="form-label"></label>
                    <input asp-for="Img" type="file" class="form-control" />

                    @if (!string.IsNullOrEmpty(Model.Cinema.ImageUrl))
                    {
                        <img src="~/Assets/Admin/img/cinema/@Model.Cinema.ImageUrl"
                             style="height:100px; margin-top:10px;" />
                    }
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-dark">← Back</a>
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>

            </form>

        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}