@model CinemaIndexVM

@{
    var cinemas = Model?.Cinemas ?? new List<Cinema>();
    var searchQuery = Model?.SearchQuery ?? "";
    var showTimeCounts = Model?.ShowTimeCounts ?? new Dictionary<int, int>();
    var currentPage = Model?.CurrentPage ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>Cinemas</h4>
        <a asp-area="Admin" asp-controller="Cinema" asp-action="Create"
           class="btn btn-primary">+ Add Cinema</a>
    </div>

    <form method="get" asp-action="Index" class="mb-4">
        <div class="input-group" style="max-width:400px;">
            <input type="text" name="q" value="@searchQuery"
                   class="form-control" placeholder="Search cinemas by name or location..." />
            <button class="btn btn-outline-primary" type="submit">
                <span class="fas fa-search"></span>
            </button>

            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @if (!cinemas.Any())
    {
        <div class="text-center text-muted py-5">
            <span class="fas fa-building fa-2x mb-3 d-block"></span>
            No cinemas found@( !string.IsNullOrEmpty(searchQuery) ? $" for \"{searchQuery}\"" : "" ).
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var cinema in cinemas)
            {
                var showCount = showTimeCounts.TryGetValue(cinema.Id, out var count) ? count : 0;

                <div class="col-md-4 mb-4" id="cinema-@cinema.Id">
                    <div class="card border-0 shadow-sm text-white">

                        <img src="@(string.IsNullOrEmpty(cinema.ImageUrl)
                            ? "/Assets/Admin/img/no-image.png"
                            : $"/Assets/Admin/img/cinema/{cinema.ImageUrl}")"
                             class="card-img" style="height:240px; object-fit:cover;" />

                        <div class="card-img-overlay d-flex flex-column justify-content-end"
                             style="background: linear-gradient(to top, rgba(0,0,0,0.6), rgba(0,0,0,0)); padding:1rem;">

                            <h5 class="mb-1">@cinema.Name</h5>

                            <div class="d-flex justify-content-between align-items-center small mb-2 text-white-50">
                                <div>@(cinema.Location ?? "Unknown") • ⭐ @(cinema.Rate)</div>
                                <div>@showCount showtimes</div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex gap-2">
                                    <a asp-area="Admin" asp-controller="Cinema" asp-action="Update"
                                       asp-route-id="@cinema.Id"
                                       class="btn btn-sm btn-outline-warning">✏️ Edit</a>

                                    <a href="#" class="btn btn-sm btn-outline-danger"
                                       onclick="deleteCinema(event, @cinema.Id)">🗑️ Delete</a>
                                </div>

                                @if (cinema.IsActive)
                                {
                                    <span class="d-flex align-items-center text-success fw-semibold status-glow">
                                        <span class="rounded-circle bg-success me-2 status-dot"></span> Active
                                    </span>
                                }
                                else
                                {
                                    <span class="d-flex align-items-center text-danger fw-semibold status-glow">
                                        <span class="rounded-circle bg-danger me-2 status-dot"></span> Inactive
                                    </span>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(currentPage - 1)"
                       asp-route-q="@searchQuery">Previous</a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-q="@searchQuery">@i</a>
                    </li>
                }

                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(currentPage + 1)"
                       asp-route-q="@searchQuery">Next</a>
                </li>

            </ul>

            <div class="text-center text-muted mt-2">
                Page @currentPage of @totalPages
            </div>
        </nav>
    }
</div>

<!-- Anti-forgery token -->
<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

<style>
    .status-glow { text-shadow: 0 0 6px currentColor; font-size: 0.9rem; }
    .status-dot  { width: 10px; height: 10px; display: inline-block; }
</style>

@section Scripts {
<script>
    function deleteCinema(e, id) {
        e.preventDefault();

        if (!confirm("Are you sure you want to delete this cinema?")) return;

        const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;

        fetch(`/Admin/Cinema/Delete/${id}`, {
            method: "POST",
            headers: {
                "RequestVerificationToken": token
            }
        })
        .then(res => {
            if (res.ok) {
                const el = document.getElementById(`cinema-${id}`);
                if (el) {
                    el.style.transition = "opacity 0.4s, transform 0.4s";
                    el.style.opacity = "0";
                    el.style.transform = "scale(0.95)";
                    setTimeout(() => el.remove(), 400);
                }
            } else {
                alert("Failed to delete cinema");
            }
        })
        .catch(() => alert("Server error"));
    }
</script>
}