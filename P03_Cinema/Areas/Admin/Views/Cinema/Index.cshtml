@model CinemaIndexVM

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>Cinemas</h4>
        <a href="/admin/cinema/create" class="btn btn-primary">+ Add Cinema</a>
    </div>

    <form method="get" asp-action="Index" class="mb-4">
        <div class="input-group" style="max-width:400px;">
            <input type="text" name="q" value="@Model.SearchQuery"
                   class="form-control" placeholder="Search cinemas by name or location..." />
            <button class="btn btn-outline-primary" type="submit">
                <span class="fas fa-search"></span>
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @if (!Model.Cinemas.Any())
    {
        <div class="text-center text-muted py-5">
            <span class="fas fa-building fa-2x mb-3 d-block"></span>
            No cinemas found@(!string.IsNullOrEmpty(Model.SearchQuery) ? $" for \"{Model.SearchQuery}\"" : "").
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var cinema in Model.Cinemas)
            {
                <div class="col-md-4 mb-4" id="cinema-@cinema.Id">
                    <div class="card border-0 shadow-sm text-white">
                        <img src="~/Assets/Admin/img/cinema/@cinema.ImageUrl"
                             class="card-img" style="height:240px; object-fit:cover;">
                        <div class="card-img-overlay d-flex flex-column justify-content-end"
                             style="background: linear-gradient(to top, rgba(0,0,0,0.5), rgba(0,0,0,0)); padding:1rem;">
                            <h5 class="mb-1 text-white">@cinema.Name</h5>
                            <div class="d-flex justify-content-between align-items-center small mb-2 text-white-50">
                                <div>@cinema.Location • ⭐ @cinema.Rate</div>
                                <div>
                                    @(Model.ShowTimeCounts.ContainsKey(cinema.Id)
                                        ? Model.ShowTimeCounts[cinema.Id] : 0) showtimes
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex gap-2">
                                    <a asp-area="Admin" asp-controller="Cinema" asp-action="Update"
                                       asp-route-id="@cinema.Id"
                                       class="btn btn-sm btn-outline-warning me-2">✏️ Edit</a>
                                    <a href="#" class="btn btn-sm btn-outline-danger"
                                       onclick="deleteCinema(event, @cinema.Id)">🗑️ Delete</a>
                                </div>
                                @if (cinema.IsActive)
                                {
                                    <span class="d-flex align-items-center text-success fw-semibold status-glow mb-0">
                                        <span class="rounded-circle bg-success me-2 status-dot"></span> Active
                                    </span>
                                }
                                else
                                {
                                    <span class="d-flex align-items-center text-danger fw-semibold status-glow mb-0">
                                        <span class="rounded-circle bg-danger me-2 status-dot"></span> Inactive
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-q="@Model.SearchQuery">Previous</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-q="@Model.SearchQuery">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-q="@Model.SearchQuery">Next</a>
                </li>
            </ul>
            <div class="text-center text-muted mt-2">
                Page @Model.CurrentPage of @Model.TotalPages
            </div>
        </nav>
    }
</div>

<style>
    .status-glow { text-shadow: 0 0 6px currentColor; font-size: 0.9rem; user-select: none; }
    .status-dot  { width: 10px; height: 10px; display: inline-block; }
</style>

@section Scripts {
    <script>
    function deleteCinema(e, id) {
        e.preventDefault();
        if (!confirm("Are you sure you want to delete this cinema?")) return;
        fetch(`/Admin/Cinema/Delete/${id}`, {
            method: "POST"
        })
        .then(response => {
            if (response.ok) {
                showToast("Cinema deleted successfully!", "success");
                const el = document.getElementById(`cinema-${id}`);
                if (el) {
                    el.style.transition = "opacity 0.4s, transform 0.4s";
                    el.style.opacity = "0";
                    el.style.transform = "scale(0.95)";
                    setTimeout(() => el.remove(), 400);
                }
            } else {
                showToast("Failed to delete cinema", "error");
            }
        })
        .catch(() => {
            showToast("Server error occurred", "error");
        });
    }
    </script>
}