@model ResetPasswordVM
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Reset Password";
    ViewBag.BgImage = "/assets/admin/img/generic/20.jpg";
}

<h3 class="text-center">Reset password</h3>

<form class="mt-3" method="post" asp-action="ResetPassword">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="UserId" />

    <div asp-validation-summary="ModelOnly" class="text-danger fs-10 mb-3"></div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">New Password</label>
        <input asp-for="Password"
               class="form-control"
               type="password" />
        <span asp-validation-for="Password" class="text-danger fs-10"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
        <input asp-for="ConfirmPassword"
               class="form-control"
               type="password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger fs-10"></span>
    </div>

    <button class="btn btn-primary d-block w-100 mt-3" type="submit">
        Set password
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
