@model AuthMessageVM
@{
    ViewData["Title"] = "Email";
    ViewBag.BgImage = "/assets/admin/img/generic/16.jpg";
    ViewBag.BgPosition = "50% 30%";
}

<div class="text-center">

    <img class="d-block mx-auto mb-4"
         src="@Model.IconPath"
         alt="Status" width="100" />

    <h3 class="mb-2">@Model.Title</h3>
    <p>@Model.Message</p>

    @if (Model.RedirectAction == "ValidateOTP")
    {
        <a class="btn btn-primary btn-sm mt-3"
               asp-action="ValidateOTP">
            Enter verification code
        </a>
        <div class="mt-3">
            <a class="fs-10 text-600" asp-action="ForgotPassword">
                Didn't receive it? Try again
            </a>
        </div>
    }
    else if (Model.Email is not null)
    {
        <form asp-action="ResendLink" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="email" value="@Model.Email" />

            <button type="submit" class="btn btn-link">
                Resend verification email
            </button>
        </form>

        <a class="btn btn-primary btn-sm mt-3" asp-action="Login">
            Return to login
        </a>
    }
    else
    {
        <a class="btn btn-primary btn-sm mt-3" asp-action="Login">
            Return to login
        </a>
    }

</div>
