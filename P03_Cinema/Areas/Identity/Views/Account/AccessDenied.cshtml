@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex justify-content-center" style="min-height:60vh; padding-top:120px;">

    <div class="position-relative text-center rounded-4"
         style="
        max-width:1100px;
        width:100%;
        padding:6rem 5rem;
        border:1px solid rgba(255,255,255,0.08);
        background:linear-gradient(145deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
        backdrop-filter:blur(14px);
        box-shadow:0 0 80px rgba(0,0,0,0.85);
        overflow:hidden;">

            <!-- BACKGROUND -->
            <div class="position-absolute top-50 start-50 translate-middle text-center"
                 style="pointer-events:none; opacity:.04; line-height:1;">

                <div style="font-size:240px;">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>

                <div style="font-size:420px; font-weight:900; margin-top:-90px;">
                    403
                </div>

                <div style="font-size:40px; letter-spacing:18px; margin-top:-10px;">
                    FORBIDDEN
                </div>

            </div>

            <!-- ICON -->
            <div class="mb-4 text-danger" style="font-size:6rem;">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>

            <!-- TITLE -->
            <h1 class="fw-bold text-light mb-3" style="font-size:3.2rem;">
                Access Denied
            </h1>

            <!-- MESSAGE -->
            <p class="text-secondary mb-5" style="font-size:1.25rem;">
                <i class="bi bi-lock-fill me-1"></i>
                You don’t have permission to view this page.<br>
                <i class="bi bi-person-exclamation me-1"></i>
                Please check your credentials or contact support.
            </p>

            <!-- BUTTONS -->
            <div class="d-flex justify-content-center gap-3">
                <a href="/" class="btn btn-primary px-5 py-3 rounded-pill fw-semibold">
                    <i class="bi bi-house-door-fill me-1"></i> Home
                </a>

                <button onclick="history.back()" class="btn btn-outline-light px-5 py-3 rounded-pill">
                    <i class="bi bi-arrow-left me-1"></i> Go Back
                </button>
            </div>

        </div>

    </div>

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>